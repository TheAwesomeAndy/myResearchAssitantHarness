# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# LaTeX
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.run.xml
*.synctex.gz
*.toc

# Local data and secrets
.env
.env.*
secrets/
data_local/
private_data/
restricted_data/

# Harness run outputs (ephemeral, regenerated each run).
# The memory journal (harness/memory/memory.jsonl) is intentionally NOT
# ignored: it is durable, reviewable project knowledge that should be
# versioned. Only per-run history and generated reports are ignored.
harness/reports/*.json
harness/reports/*.jsonl
harness/reports/*.log
harness/reports/*.txt
harness/reports/*.md

# The fixtures/ memory samples are demo data and must stay tracked.
!fixtures/**
